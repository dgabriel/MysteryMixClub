# MysteryMixClub environment variables
# Copy to .env (gitignored) and fill in values for local development.
# Never commit real values to git.

# --- Backend ---

# Postgres connection string, e.g. postgresql+asyncpg://user:pass@localhost:5432/mysterymixclub
DATABASE_URL=

# JWT signing key. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Resend API key for magic-link and round-notification email
RESEND_API_KEY=

# Overrides the From address on ALL outbound email when set. Leave empty in
# staging/prod to use the verified-domain defaults (login@ / notifications@).
# Resend rejects sends from an unverified domain, so locally set this to a
# sender Resend accepts, e.g. onboarding@resend.dev. Note: until your own
# domain is verified at https://resend.com/domains, onboarding@resend.dev only
# delivers to the email you signed up to Resend with.
EMAIL_FROM=

# Comma-separated platform-admin emails. These accounts can hard-delete bad
# actors via /admin and see is_platform_admin on /users/me. NOT a login gate.
SEED_ADMIN_EMAILS=

# Hard cap on total accounts during the beta; new sign-ups are blocked at the
# cap, existing users unaffected. Leave blank to use the default (1500); 0 = unlimited.
MAX_USERS=

# Song search and paste-a-link resolution use keyless public APIs (Deezer,
# iTunes, Spotify/YouTube oEmbed) — no key required (MYS-81 replaced Odesli).

# YouTube Data API v3 key (server-side only; never expose to the client).
# Resolves a song -> YouTube video id for the round playlist link (MYS-78).
# Create at https://console.cloud.google.com (enable "YouTube Data API v3").
YOUTUBE_API_KEY=

# Spotify app credentials for per-user OAuth playlist creation (MYS-83).
# Server-side only; the client secret must never reach the browser. Register an
# app at https://developer.spotify.com/dashboard and add SPOTIFY_REDIRECT_URI to
# its "Redirect URIs" (must match exactly). The redirect points at the API's
# callback. Spotify no longer accepts "localhost" — use the explicit loopback IP
# locally, e.g. http://127.0.0.1:8000/api/v1/spotify/callback.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

# Shared-account playlist generation (MYS-169). Spotify's extended quota needs
# 250k MAU, so the app stays in Development Mode indefinitely (~25 allowlisted
# accounts) — per-user OAuth playlist creation above is dormant. One dedicated
# MysteryMixClub Spotify account creates each round's playlist PUBLIC and every
# member gets the link. Set to the UUID of the app user (users.id) whose
# spotify_connections row holds that dedicated account's token — connect it once
# through the existing /spotify/connect flow, logged in as that app user. Empty =
# playlist generation is hidden.
SPOTIFY_PLAYLIST_ACCOUNT_USER_ID=

# Apple Music developer token (MYS-104/MYS-105). Server-side only — mints an
# ES256-signed JWT that identifies the app to Apple's Music API. Requires a paid
# Apple Developer Program membership. Create a MusicKit key in the Apple Developer
# portal (Certificates, IDs & Profiles -> Keys -> Media Services) to get the Key
# ID and download the .p8; the Team ID is in your membership details. Never expose
# the .p8 to the client. For a single-line deploy secret, replace the PEM newlines
# with literal \n — the service accepts both forms.
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY=

# Comma-separated list of allowed CORS origins, e.g. http://localhost:5173,https://www.mysterymixclub.com
ALLOWED_ORIGINS=

# development | production
ENVIRONMENT=development

# Base URL used to build magic-link URLs in emails, e.g. http://localhost:5173 in dev
APP_BASE_URL=

# Public base URL of the API, used for backend-direct email links (one-click
# unsubscribe). Falls back to APP_BASE_URL when unset. e.g. http://localhost:8000 in dev
API_BASE_URL=

# Staging email sink. When EMAIL_REDIRECT_TO_TEST=true, every outbound email is
# redirected to EMAIL_TEST_RECIPIENT instead of the real recipient (toggle on
# staging to test without emailing real people). If the flag is on but no
# recipient is set, email is suppressed. Leave the flag off in production.
EMAIL_REDIRECT_TO_TEST=false
EMAIL_TEST_RECIPIENT=

# Public waitlist (MYS-215, temporary pre-launch flow). When true, the login
# page and POST /waitlist accept join requests; when false (default), that
# route 404s and the frontend falls back to the "email us" copy.
WAITLIST_ENABLED=false

# --- Frontend ---

# Base URL the React app uses to reach the FastAPI backend
VITE_API_BASE_URL=http://localhost:8000
