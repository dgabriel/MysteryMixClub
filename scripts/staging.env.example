# Template for /etc/mysterymixclub/staging.env on the Droplet.
# Copy to /etc/mysterymixclub/staging.env and fill in real values.
# NEVER commit the populated file — it holds live secrets.

# Async SQLAlchemy URL for the local staging Postgres (created by
# bootstrap-droplet.sh). The app also accepts a bare postgresql:// URL and
# normalizes it to the +asyncpg driver, but be explicit here.
DATABASE_URL=postgresql+asyncpg://mmc_staging:CHANGE_ME@localhost:5432/mysterymixclub_staging

# JWT signing key (read by the app as SECRET_KEY). Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME

# Email + music-link integrations. Set RESEND_API_KEY so magic-link sign-in
# emails are actually sent; leave it empty and links are only logged to the
# service journal (journalctl -u mysterymixclub-api).
RESEND_API_KEY=
# YouTube Data API v3 key — resolves a song -> YouTube video id for the mystery-mix
# playlist link (MYS-78). Optional: leave empty and the playlist link is simply
# omitted. Song search and paste-link resolution use Deezer (keyless), no key needed.
YOUTUBE_API_KEY=

# Spotify per-user OAuth playlist creation (MYS-83). Optional: leave empty and
# the feature is hidden. SPOTIFY_REDIRECT_URI must match a redirect URI on the
# Spotify app and point at this API's /spotify/callback.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

# Shared-account playlist generation (MYS-169) — see .env.example at repo root
# for the full explanation. UUID of the app user whose spotify_connections row
# is the dedicated MysteryMixClub Spotify account. Empty = feature hidden.
SPOTIFY_PLAYLIST_ACCOUNT_USER_ID=

# Apple Music (MYS-104/105/106/108). All three are required together — with any
# of them empty the Apple UI renders nothing at all and Apple links fall back to
# the keyless iTunes lookup, which is a normal, supported state.
#   TEAM_ID     — Apple Developer membership details page, 10 chars.
#   KEY_ID      — the 10 chars in the downloaded AuthKey_XXXXXXXXXX.p8 filename.
#   PRIVATE_KEY — the .p8 file's full PEM contents. In this file it must be ONE
#                 line: keep the quotes and use literal \n between PEM lines,
#                 e.g. "-----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----"
#                 (the app un-escapes them — see apple_music_token.py).
# The .p8 download is one-time and non-recoverable; keep the original in a
# password manager. Never commit a populated copy of this file.
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY=

# Marks this deployment as staging (see backend/app/config.py).
ENVIRONMENT=staging

# Comma-separated CORS origins, plus the base URL used to build magic-link emails.
ALLOWED_ORIGINS=https://staging.mysterymixclub.com
APP_BASE_URL=https://staging.mysterymixclub.com

# Frontend API base, baked into the SPA at build time. Leave EMPTY so the SPA
# calls the API same-origin (relative /api/v1/...), which nginx proxies to the
# backend. Only set an absolute URL if the API lives on a different host.
VITE_API_BASE_URL=
